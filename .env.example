EMBER_STORAGE_BACKEND=local
EMBER_DATA_ROOT=./data

# --- GCS (backend=gcs) ---
# Single service-account credential for the whole app (DuckDB, GDAL/TiTiler, storage client).
# Local/docker: path to the service-account JSON. Cloud Run: leave blank to use the attached SA.
GCS_BUCKET=ember-data
# Optional folder within the bucket that holds tables/ and cogs/ (e.g. EMBER). Blank = bucket root.
GCS_PREFIX=
GOOGLE_APPLICATION_CREDENTIALS=

# --- service wiring ---
TILER_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8501
GEOJSON_SIMPLIFY_TOLERANCE=0.0005
